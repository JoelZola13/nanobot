# Street Voices Listmonk — local environment
# Copy to .env and fill in real values. NEVER commit .env.

# --- Listmonk admin (auto-created on first boot) ---
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=$treetvoices26

# --- Local ports (change if 9001/15432 conflict) ---
LISTMONK_PORT=9001
LISTMONK_DB_PORT=15432

# --- Brand / site settings ---
SV_ROOT_URL=http://localhost:9001
SV_FROM_EMAIL=StreetVoices <communications@streetvoices.ca>

# --- SendGrid SMTP (required to actually send email) ---
# Get a key at https://app.sendgrid.com/settings/api_keys
# Restricted Access → Mail Send: Full Access. Name it "Listmonk local".
SENDGRID_API_KEY=SG.replace_with_your_key

# --- Optional: seed behaviour ---
# Set to 1 to overwrite existing branded template content on each seed run.
SEED_FORCE_UPDATE=0
