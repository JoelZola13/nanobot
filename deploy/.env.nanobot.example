# Nanobot API Environment Variables
# Copy to ../.env.nanobot and fill in your values

# Groq API (used for WhatsApp voice transcription)
GROQ_API_KEY=your-groq-api-key

# Postiz Social Media Integration
NANOBOT_TOOLS__POSTIZ__ENABLED=true
NANOBOT_TOOLS__POSTIZ__BASE_URL=http://host.docker.internal:4007
NANOBOT_TOOLS__POSTIZ__API_KEY=your-postiz-api-key
NANOBOT_TOOLS__POSTIZ__API_KEY_PREFIX=
NANOBOT_TOOLS__POSTIZ__PUBLISH_PATH=/api/public/v1/posts
NANOBOT_TOOLS__POSTIZ__DEFAULT_INTEGRATION_ID=your-default-integration-id
